# ============================================================
# 校园餐饮管理系统 .gitignore
# ============================================================

# ======================== 通用 ========================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*~

# ======================== IDE ========================
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln


# ======================== 运行时 ========================
.pids/
.logs/

# ======================== 后端 (Java/Maven) ========================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.jar
backend/*.war

# ======================== 管理端 (Node.js) ========================
admin/node_modules/
admin/dist/
admin/.env.local
admin/.env.*.local

# ======================== 用户端 (Node.js) ========================
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local

# ======================== 环境变量 ========================
*.local

